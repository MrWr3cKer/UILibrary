local Themes = {
	Default = { Background = Color3.fromRGB(30, 30, 30), DarkElement = Color3.fromRGB(60, 60, 60), LightElement = Color3.fromRGB(95, 95, 95), Accent = Color3.fromRGB(28, 90, 190), Text = Color3.fromRGB(255, 255, 255) },
	Ocean = { Background = Color3.fromRGB(15, 25, 35), DarkElement = Color3.fromRGB(25, 45, 60), LightElement = Color3.fromRGB(40, 75, 100), Accent = Color3.fromRGB(0, 150, 255), Text = Color3.fromRGB(255, 255, 255) },
	Blood = { Background = Color3.fromRGB(25, 15, 15), DarkElement = Color3.fromRGB(50, 20, 20), LightElement = Color3.fromRGB(80, 30, 30), Accent = Color3.fromRGB(220, 40, 40), Text = Color3.fromRGB(255, 220, 220) },
	Forest = { Background = Color3.fromRGB(15, 25, 15), DarkElement = Color3.fromRGB(30, 50, 30), LightElement = Color3.fromRGB(45, 75, 45), Accent = Color3.fromRGB(60, 180, 80), Text = Color3.fromRGB(220, 255, 220) },
}
local Colors = Themes.Default

function Utility:Colorize(element, property, colorName)
	element[property] = Colors[colorName]
	table.insert(Library.ThemedElements, {Element = element, Property = property, ColorName = colorName})
end

function Utility:UpdateThemeColor(element, property, newColorName)
	for _, data in pairs(Library.ThemedElements) do
		if data.Element == element and data.Property == property then
			data.ColorName = newColorName
			return
		end
	end
	Utility:Colorize(element, property, newColorName)
end

function Library:SetTheme(themeName)
	if Themes[themeName] then
		Colors = Themes[themeName]
		for _, data in pairs(Library.ThemedElements) do
			if data.Element and data.Element.Parent then
				Utility:Tween(data.Element, {[data.Property] = Colors[data.ColorName]}, 0.3)
			end
		end
	end
end

function Utility:Tween(obj, properties, duration)
	local tweenInfo = TweenInfo.new(duration or 0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
	local tween = TweenService:Create(obj, tweenInfo, properties)
	tween:Play()
	return tween
end

function Utility:MakeDraggable(topBar, mainFrame)
	local dragging, dragInput, dragStart, startPos
	topBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = mainFrame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	topBar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
end

