					Utility:Tween(Switch, {BackgroundColor3 = Colors.LightElement}, 0.2)
					Utility:Tween(Dot, {Position = UDim2.new(0, 3, 0.5, 0)}, 0.2)
				end
				callback(state)
			end

			Library.Configurables[flag] = { Type = "Toggle", Value = state, Set = SetState }
			table.insert(Library.Toggles, {State = state, Callback = callback})

			Btn.MouseButton1Click:Connect(function()
