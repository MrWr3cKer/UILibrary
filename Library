		function SectionAPI:create_keybind(options)
			local kbText = options.text or "Keybind"
			local flag = options.flag or kbText
			local currentKey = options.default or Enum.KeyCode.RightShift
			local tooltip = options.tooltip
			local callback = options.Callback or function() end

			local Frame = Instance.new("Frame", InnerBox)
			Frame.Size = UDim2.new(1, 0, 0, 36)
			Frame.BackgroundTransparency = 1
			RegisterElement(Frame)

			local Label = Instance.new("TextLabel", Frame)
			Label.Size = UDim2.new(1, -100, 1, 0)
			Label.BackgroundTransparency = 1
			Label.Text = kbText
			Label.Font = Enum.Font.Arimo
			Utility:Colorize(Label, "TextColor3", "Text")
			Label.TextSize = 16
			Label.TextXAlignment = Enum.TextXAlignment.Left

			Library:AddTooltip(Label, tooltip)

			local BindBtn = Instance.new("TextButton", Frame)
			BindBtn.Size = UDim2.new(0, 90, 0, 24)
			BindBtn.AnchorPoint = Vector2.new(1, 0.5)
			BindBtn.Position = UDim2.new(1, 0, 0.5, 0)
			Utility:Colorize(BindBtn, "BackgroundColor3", "LightElement")
			Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 6)
			BindBtn.Text = currentKey.Name
			Utility:Colorize(BindBtn, "TextColor3", "Text")
			BindBtn.Font = Enum.Font.Arimo
			BindBtn.TextSize = 14

			local isThisBinding = false

			local function SetKey(keyObj)
				currentKey = keyObj
				BindBtn.Text = currentKey.Name
				Utility:UpdateThemeColor(BindBtn, "BackgroundColor3", "LightElement")
				Utility:Tween(BindBtn, {BackgroundColor3 = Colors.LightElement}, 0.2)

				if Library.Configurables[flag] then
					Library.Configurables[flag].Value = currentKey.Name
				end

				callback(currentKey)
			end

			Library.Configurables[flag] = {
				Type = "Keybind",
				Value = currentKey.Name,
				Set = function(val)
					local key
					pcall(function() key = Enum.KeyCode[val] end)
					if not key then
						pcall(function() key = Enum.UserInputType[val] end)
					end
					if key then
						SetKey(key)
					end
				end
			}

			BindBtn.MouseButton1Click:Connect(function()
				Library.IsBinding = true
				isThisBinding = true
				BindBtn.Text = "..."
				Utility:UpdateThemeColor(BindBtn, "BackgroundColor3", "Accent")
				Utility:Tween(BindBtn, {BackgroundColor3 = Colors.Accent}, 0.2)
			end)

			UserInputService.InputBegan:Connect(function(input)
				if isThisBinding then
					local validKey = false

					if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
						currentKey = input.KeyCode
						validKey = true
					elseif input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
						currentKey = input.UserInputType
						validKey = true
					end

					if validKey then
						isThisBinding = false
						SetKey(currentKey)

						task.spawn(function()
							task.wait(0.1)
							Library.IsBinding = false
						end)
					end
				else
					if input.KeyCode == currentKey or input.UserInputType == currentKey then
						if not UserInputService:GetFocusedTextBox() then
							callback(currentKey)
						end
					end
				end
			end)
		end


		-- ================= LAGE COLOR PICKER =================
		function SectionAPI:create_colorpicker(options)
			local cpText = options.text or "Color Picker"
			local flag = options.flag or cpText
			local defaultColor = options.color or Color3.fromRGB(255, 255, 255)
			local defaultAlpha = options.alpha or 1
			local tooltip = options.tooltip
			local callback = options.Callback or function() end

			local h, s, v = Color3.toHSV(defaultColor)
			local a = defaultAlpha

			local Frame = Instance.new("Frame", InnerBox)
			Frame.Size = UDim2.new(1, 0, 0, 36)
			Frame.AutomaticSize = Enum.AutomaticSize.Y
			Utility:Colorize(Frame, "BackgroundColor3", "LightElement")
			Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 6)
			RegisterElement(Frame)

			local TopBtn = Instance.new("TextButton", Frame)
			TopBtn.Size = UDim2.new(1, 0, 0, 36)
			TopBtn.BackgroundTransparency = 1
			TopBtn.Text = "  " .. cpText
			TopBtn.FontFace = Font.new("rbxasset://fonts/families/Arimo.json", Enum.FontWeight.Bold)
			Utility:Colorize(TopBtn, "TextColor3", "Text")
			TopBtn.TextSize = 16
			TopBtn.TextXAlignment = Enum.TextXAlignment.Left

			local ColorPreview = Instance.new("Frame", TopBtn)
			ColorPreview.Size = UDim2.new(0, 24, 0, 24)
			ColorPreview.Position = UDim2.new(1, -10, 0.5, 0)
			ColorPreview.AnchorPoint = Vector2.new(1, 0.5)
			ColorPreview.BackgroundColor3 = defaultColor
			Instance.new("UICorner", ColorPreview).CornerRadius = UDim.new(0, 4)

			local PickerContainer = Instance.new("Frame", Frame)
			PickerContainer.Size = UDim2.new(1, 0, 0, 0)
			PickerContainer.Position = UDim2.new(0, 0, 0, 36)
			PickerContainer.BackgroundTransparency = 1
			PickerContainer.Visible = false
			PickerContainer.AutomaticSize = Enum.AutomaticSize.Y

			local Layout = Instance.new("UIListLayout", PickerContainer)
			Layout.Padding = UDim.new(0, 8)

			local ColorMap = Instance.new("TextButton", PickerContainer)
			ColorMap.Size = UDim2.new(1, -20, 0, 150)
			ColorMap.Text = ""
			ColorMap.AutoButtonColor = false
			ColorMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)

			local MapDot = Instance.new("Frame", ColorMap)
			MapDot.Size = UDim2.new(0, 12, 0, 12)
			MapDot.AnchorPoint = Vector2.new(0.5, 0.5)
			MapDot.Position = UDim2.new(s, 0, 1 - v, 0)
			MapDot.BackgroundColor3 = Color3.new(1, 1, 1)

			local open = false

			TopBtn.MouseButton1Click:Connect(function()
				open = not open
				PickerContainer.Visible = open
			end)

			local function UpdateColor()
				local col = Color3.fromHSV(h, s, v)

				ColorPreview.BackgroundColor3 = col
				ColorMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)

				if Library.Configurables[flag] then
					Library.Configurables[flag].Value = string.format("%f,%f,%f,%f", h, s, v, a)
				end

				callback(col, a)
			end

			Library.Configurables[flag] = {
				Type = "ColorPicker",
				Value = string.format("%f,%f,%f,%f", h, s, v, a),
				Set = function(val)
					local parsed = string.split(val, ",")

					if #parsed == 4 then
						h = tonumber(parsed[1])
						s = tonumber(parsed[2])
						v = tonumber(parsed[3])
						a = tonumber(parsed[4])

						MapDot.Position = UDim2.new(s, 0, 1 - v, 0)

						UpdateColor()
					end
				end
			}

			local dragging = false

			local function update(input)
				local percentX = math.clamp((input.Position.X - ColorMap.AbsolutePosition.X) / ColorMap.AbsoluteSize.X, 0, 1)
				local percentY = math.clamp((input.Position.Y - ColorMap.AbsolutePosition.Y) / ColorMap.AbsoluteSize.Y, 0, 1)

				s = percentX
				v = 1 - percentY

				MapDot.Position = UDim2.new(percentX, 0, percentY, 0)

				UpdateColor()
			end

			ColorMap.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					update(input)
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					update(input)
				end
			end)

			UpdateColor()
		end

		return SectionAPI
	end

	-- ==========================================
	-- ### SETTINGS & CONFIG SYSTEM ###
	-- ==========================================
	local SettingsSection = Window:section("Settings", 9999)

	SettingsSection:create_dropdown({
		text = "Theme",
		list = {"Default", "Ocean", "Blood", "Forest", "Amethyst", "Midnight"},
		tooltip = "Velg fargetema for menyen",
		Callback = function(val) Library:SetTheme(val) end
	})

	SettingsSection:create_toogle({
		text = "Watermark",
		flag = "ShowWatermark",
		state = false,
		tooltip = "Viser FPS, Ping og tid i hjørnet",
		Callback = function(val) WatermarkUI.Visible = val end
	})

	SettingsSection:create_keybind({
		text = "Menu Keybind",
		flag = "MenuKeybind",
		default = Enum.KeyCode.RightShift,
		tooltip = "Bestemmer hvilken tast som skjuler scriptet",
		Callback = function(key)
			Library.ToggleKey = key
		end
	})

	local function UpdateConfigList()
		local list = {}
		if HasFileSystem then
			if not isfolder("MyCheatHub") then makefolder("MyCheatHub") end
			for _, file in ipairs(listfiles("MyCheatHub")) do
				local name = file:match("([^/^\\]+)%.json$")
				if name then table.insert(list, name) end
			end
		else
			for name, _ in pairs(MockFilesystem) do table.insert(list, name) end
		end
		return list
	end

	local ConfigNameInput = SettingsSection:create_input({
		text = "Skriv Config Navn...",
		tooltip = "Navnet på filen du vil lagre"
	})

	local currentSelectedConfig = ""
	local ConfigDropdown = SettingsSection:create_dropdown({
		text = "Saved Configs",
		list = UpdateConfigList(),
		tooltip = "Velg en lagret config",
		Callback = function(val) currentSelectedConfig = val end
	})

	SettingsSection:create_button({
		text = "Save Config",
		tooltip = "Lagrer alle innstillinger til filen",
		Callback = function()
			local name = ConfigNameInput.Text
			if name == "" then Library:Notify("Feil", "Du må skrive et navn først!", 3) return end

			local dataToSave = {}
			for flag, cfg in pairs(Library.Configurables) do
				dataToSave[flag] = cfg.Value
			end
			local json = HttpService:JSONEncode(dataToSave)

			if HasFileSystem then
				writefile("MyCheatHub/"..name..".json", json)
			else
				MockFilesystem[name] = json
			end
			Library:Notify("Lagret", "Config '" .. name .. "' er lagret!", 4)
			ConfigDropdown:Refresh(UpdateConfigList())
		end
	})

	SettingsSection:create_button({
		text = "Load Config",
		tooltip = "Laster inn valgt config fra menyen",
		Callback = function()
			if currentSelectedConfig == "" then Library:Notify("Feil", "Velg en config i menyen først!", 3) return end

			local json = ""
			if HasFileSystem then
				json = readfile("MyCheatHub/"..currentSelectedConfig..".json")
			else
				json = MockFilesystem[currentSelectedConfig]
			end

			if json then
				local data = HttpService:JSONDecode(json)
				for flag, val in pairs(data) do
					if Library.Configurables[flag] then
						Library.Configurables[flag].Set(val)
					end
				end
				Library:Notify("Lastet inn", "Config '" .. currentSelectedConfig .. "' er lastet!", 4)
			end
		end
	})

	SettingsSection:create_button({
		text = "Update Config",
		tooltip = "Overskriver den valgte configen med nåværende instillinger",
		Callback = function()
			if currentSelectedConfig == "" then Library:Notify("Feil", "Velg en config å oppdatere!", 3) return end

			local dataToSave = {}
			for flag, cfg in pairs(Library.Configurables) do
				dataToSave[flag] = cfg.Value
			end
			local json = HttpService:JSONEncode(dataToSave)

			if HasFileSystem then
				writefile("MyCheatHub/"..currentSelectedConfig..".json", json)
			else
				MockFilesystem[currentSelectedConfig] = json
			end
			Library:Notify("Oppdatert", "Config '" .. currentSelectedConfig .. "' er overskrevet!", 4)
		end
	})

	return Window
end

return Library
