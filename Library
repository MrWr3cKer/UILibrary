		function SectionAPI:create_slider(options)
			local sldText = options.text or "Slider"
			local flag = options.flag or sldText
			local min = options.min_value or 0
			local max = options.max_value or 100
			local start = options.start_value or min
			local inc = options.increment or 1
			local tooltip = options.tooltip
			local callback = options.Callback or function() end

			local Frame = Instance.new("Frame", InnerBox)
			Frame.Size = UDim2.new(1, 0, 0, 50)
			Frame.BackgroundTransparency = 1
			RegisterElement(Frame)

			local Label = Instance.new("TextLabel", Frame)
			Label.Size = UDim2.new(1, -50, 0, 20)
			Label.Position = UDim2.new(0, 0, 0, 5)
			Label.BackgroundTransparency = 1
			Label.Text = sldText
			Label.Font = Enum.Font.Arimo
			Utility:Colorize(Label, "TextColor3", "Text")
			Label.TextSize = 16
			Label.TextXAlignment = Enum.TextXAlignment.Left

			local ValLabel = Instance.new("TextLabel", Frame)
			ValLabel.Size = UDim2.new(0, 50, 0, 20)
			ValLabel.Position = UDim2.new(1, -50, 0, 5)
			ValLabel.BackgroundTransparency = 1
			ValLabel.Text = tostring(start)
			ValLabel.Font = Enum.Font.Arimo
			Utility:Colorize(ValLabel, "TextColor3", "Text")
			ValLabel.TextSize = 16
			ValLabel.TextXAlignment = Enum.TextXAlignment.Right

			local Track = Instance.new("Frame", Frame)
			Track.Size = UDim2.new(1, 0, 0, 6)
			Track.Position = UDim2.new(0, 0, 0, 35)
			Utility:Colorize(Track, "BackgroundColor3", "LightElement")
			Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

			local percentage = (start - min) / (max - min)

			local Fill = Instance.new("Frame", Track)
			Fill.Size = UDim2.new(percentage, 0, 1, 0)
			Utility:Colorize(Fill, "BackgroundColor3", "Accent")
			Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

			local Dot = Instance.new("Frame", Track)
			Dot.Size = UDim2.new(0, 14, 0, 14)
			Dot.AnchorPoint = Vector2.new(0.5, 0.5)
			Dot.Position = UDim2.new(percentage, 0, 0.5, 0)
			Dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)

			local Hitbox = Instance.new("TextButton", Track)
			Hitbox.Size = UDim2.new(1, 0, 1, 20)
			Hitbox.Position = UDim2.new(0, 0, 0.5, 0)
			Hitbox.AnchorPoint = Vector2.new(0, 0.5)
			Hitbox.BackgroundTransparency = 1
			Hitbox.Text = ""

			Library:AddTooltip(Hitbox, tooltip)

			local function SetValue(val)
				val = math.clamp(val, min, max)
				local newPercent = (val - min) / (max - min)
				ValLabel.Text = tostring(val)
				Utility:Tween(Fill, {Size = UDim2.new(newPercent, 0, 1, 0)}, 0.1)
				Utility:Tween(Dot, {Position = UDim2.new(newPercent, 0, 0.5, 0)}, 0.1)
				Library.Configurables[flag].Value = val
				callback(val)
			end

			Library.Configurables[flag] = { Type = "Slider", Value = start, Set = SetValue }

			local dragging = false
			local function updateSlider(input)
				local percent = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
				local rawValue = min + (max - min) * percent
				local snappedValue = math.floor(rawValue / inc + 0.5) * inc
				SetValue(snappedValue)
			end

			Hitbox.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true; updateSlider(input)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then updateSlider(input) end
			end)
		end

