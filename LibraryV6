			if row:IsA("Frame") then
				local scale = row:FindFirstChildOfClass("UIScale")
				if not scale then scale = Instance.new("UIScale", row) end
				scale.Scale = 0.92
				task.delay((i - 1) * 0.03, function()
					if fetchToken == token and row.Parent then
