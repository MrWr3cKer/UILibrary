local ProfileCache = {}
local PROFILE_CACHE_TTL = 90
local profileHttpEnabled = pcall(function()
	game:HttpGet("https://users.roblox.com/v1/users/1")
end)

local function profileHttpGet(url)
	if not profileHttpEnabled then return nil end
	local ok, body = pcall(function()
		if syn and syn.request then
			local res = syn.request({ Url = url, Method = "GET" })
			if res and (res.Success or res.StatusCode == 200) then return res.Body end
		elseif http and http.request then
			local res = http.request({ Url = url, Method = "GET" })
			if res and (res.Success or res.StatusCode == 200) then return res.Body end
		elseif request then
			local res = request({ Url = url, Method = "GET" })
			if res and (res.StatusCode == 200 or res.Success) then return res.Body end
		end
		return game:HttpGet(url)
	end)
	if ok and type(body) == "string" and body ~= "" then return body end
	return nil
end

local function parseIsoDate(iso)
	if not iso or iso == "" then return nil end
	local y, mo, d = iso:match("(%d+)%-(%d+)%-(%d+)")
	if not y then return nil end
	return os.time({ year = tonumber(y), month = tonumber(mo), day = tonumber(d), hour = 12 })
end

local function formatMemberDuration(createdIso)
	local ts = parseIsoDate(createdIso)
	if not ts then return "Unknown" end
	local days = math.max(0, math.floor((os.time() - ts) / 86400))
	if days >= 365 then
		local y = math.floor(days / 365)
		return y .. (y == 1 and " year" or " years")
	end
	if days >= 30 then
		local m = math.floor(days / 30)
		return m .. (m == 1 and " month" or " months")
	end
	return days .. (days == 1 and " day" or " days")
end

local function formatCreatedDate(createdIso)
	local ts = parseIsoDate(createdIso)
	if not ts then return "Unknown" end
	return os.date("%b %d, %Y", ts)
end

local function fetchProfileBundle(userId)
	local cached = ProfileCache[userId]
	if cached and (tick() - cached.t) < PROFILE_CACHE_TTL then
		return cached.data
	end

	local data = {
		displayName = "—",
		username = "—",
		created = "—",
		memberFor = "—",
		gender = "Private",
		age = "Private",
		premium = "—",
		friends = "—",
		followers = "—",
		following = "—",
		status = "—",
		verified = "No",
		description = "",
		thumbnail = "",
	}

	local userJson = profileHttpGet("https://users.roblox.com/v1/users/" .. userId)
	if userJson then
		local ok, user = pcall(function() return HttpService:JSONDecode(userJson) end)
		if ok and user then
			data.displayName = user.displayName or user.name or data.displayName
			data.username = user.name or data.username
			data.created = formatCreatedDate(user.created)
			data.memberFor = formatMemberDuration(user.created)
			data.description = user.description or ""
			data.verified = user.hasVerifiedBadge and "Yes" or "No"
		end
	end

	local friendsJson = profileHttpGet("https://friends.roblox.com/v1/users/" .. userId .. "/friends/count")
	if friendsJson then
		local ok, f = pcall(function() return HttpService:JSONDecode(friendsJson) end)
		if ok and f and f.count then data.friends = tostring(f.count) end
	end

	local followersJson = profileHttpGet("https://friends.roblox.com/v1/users/" .. userId .. "/followers/count")
	if followersJson then
		local ok, f = pcall(function() return HttpService:JSONDecode(followersJson) end)
		if ok and f and f.count then data.followers = tostring(f.count) end
	end

	local followingJson = profileHttpGet("https://friends.roblox.com/v1/users/" .. userId .. "/followings/count")
	if followingJson then
		local ok, f = pcall(function() return HttpService:JSONDecode(followingJson) end)
		if ok and f and f.count then data.following = tostring(f.count) end
	end

	local premiumJson = profileHttpGet("https://premiumfeatures.roblox.com/v1/users/" .. userId .. "/validate-membership")
	if premiumJson then
		local ok, p = pcall(function() return HttpService:JSONDecode(premiumJson) end)
		if ok and p then data.premium = (p.isPremium == true) and "Yes" or "No" end
	end

	pcall(function()
		local thumbUrl = string.format(
			"https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=%d&size=180x180&format=Png&isCircular=false",
			userId
		)
		local tJson = profileHttpGet(thumbUrl)
		if tJson then
			local decoded = HttpService:JSONDecode(tJson)
			if decoded.data and decoded.data[1] and decoded.data[1].imageUrl then
				data.thumbnail = decoded.data[1].imageUrl
			end
		end
	end)

	if profileHttpEnabled then
		local body = HttpService:JSONEncode({ userIds = { userId } })
		local presOk, presBody = pcall(function()
			if syn and syn.request then
				return syn.request({
					Url = "https://presence.roblox.com/v1/presence/users",
					Method = "POST",
					Headers = { ["Content-Type"] = "application/json" },
					Body = body,
				}).Body
			end
			return HttpService:PostAsync("https://presence.roblox.com/v1/presence/users", body, Enum.HttpContentType.ApplicationJson)
		end)
		if presOk and presBody then
			local ok, pres = pcall(function() return HttpService:JSONDecode(presBody) end)
			if ok and pres.userPresences and pres.userPresences[1] then
				local p = pres.userPresences[1]
				if p.userPresenceType == 2 then
					data.status = "In Game" .. (p.lastLocation and (" · " .. p.lastLocation) or "")
				elseif p.userPresenceType == 3 then
					data.status = "In Studio"
				elseif p.userPresenceType == 1 then
					data.status = "Online"
				else
					data.status = "Offline"
				end
			end
		end
	end

	-- Gender / age rarely public for other users
	local genderJson = profileHttpGet("https://accountinformation.roblox.com/v1/users/" .. userId)
	if genderJson then
		local ok, info = pcall(function() return HttpService:JSONDecode(genderJson) end)
		if ok and info then
			if info.gender then data.gender = tostring(info.gender) end
			if info.ageBracket then data.age = tostring(info.ageBracket) end
		end
	end

	ProfileCache[userId] = { t = tick(), data = data }
	return data
end

