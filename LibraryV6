		end
		local ok = pcall(function()
			StarterGui:SetCore("PromptSendFriendRequest", target)
		end)
		if ok then
			Library:Notify("Friend Request", "Request prompt opened for " .. target.Name, 4)
		else
			Library:Notify("Friend Request", "Could not open request — try from Roblox menu.", 4)
		end
	end)

