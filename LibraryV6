			if fetchToken ~= token then return end
			Utility:Tween(DisplayNameLbl, { TextTransparency = 0 }, 0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
		end)

		pcall(function()
			local url = PlayersService:GetUserThumbnailAsync(plr.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size180x180)
			if fetchToken == token then
				ThumbImg.Image = url
