			AlphaBar.LayoutOrder = 5
			AlphaBar.Size = UDim2.new(1, 0, 0, 16)
			AlphaBar.Text = ""
			AlphaBar.AutoButtonColor = false
			AlphaBar.BorderSizePixel = 0
			AlphaBar.ClipsDescendants = true
			Utility:Colorize(AlphaBar, "BackgroundColor3", "Background")
			Instance.new("UICorner", AlphaBar).CornerRadius = UDim.new(0, 6)

			local AlphaChecker = Instance.new("Frame", AlphaBar)
			AlphaChecker.Size = UDim2.new(1, 0, 1, 0)
			AlphaChecker.BackgroundTransparency = 1
			AlphaChecker.ZIndex = 1
			local CheckerLayout = Instance.new("UIGridLayout", AlphaChecker)
			CheckerLayout.CellSize = UDim2.new(0, 8, 0, 8)
			for i = 1, 80 do
				local cell = Instance.new("Frame", AlphaChecker)
				cell.BorderSizePixel = 0
				cell.BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(70, 70, 70) or Color3.fromRGB(45, 45, 45)
			end

			local AlphaFill = Instance.new("Frame", AlphaBar)
			AlphaFill.Size = UDim2.new(1, 0, 1, 0)
			AlphaFill.BorderSizePixel = 0
			AlphaFill.ZIndex = 2
			AlphaFill.BackgroundColor3 = defaultColor
			local AlphaGradient = Instance.new("UIGradient", AlphaFill)
			AlphaGradient.Transparency = NumberSequence.new({
				NumberSequenceKeypoint.new(0, 0),
				NumberSequenceKeypoint.new(1, 1),
			})

			local AlphaDot = Instance.new("Frame", AlphaBar)
			AlphaDot.Size = UDim2.new(0, 6, 1, -4)
			AlphaDot.AnchorPoint = Vector2.new(0.5, 0.5)
			AlphaDot.Position = UDim2.new(a, 0, 0.5, 0)
			AlphaDot.BackgroundColor3 = Color3.new(1, 1, 1)
			AlphaDot.ZIndex = 4
			Instance.new("UICorner", AlphaDot).CornerRadius = UDim.new(0, 3)
			Instance.new("UIStroke", AlphaDot).Color = Color3.fromRGB(30, 30, 30)

			local RgbLabel = Instance.new("TextLabel", PickerContainer)
			RgbLabel.LayoutOrder = 6
			RgbLabel.Size = UDim2.new(1, 0, 0, 18)
			RgbLabel.BackgroundTransparency = 1
			RgbLabel.Font = Enum.Font.Arimo
			Utility:Colorize(RgbLabel, "TextColor3", "Text")
			RgbLabel.TextSize = 13
			RgbLabel.TextXAlignment = Enum.TextXAlignment.Left

			local open = false
			local function setPickerOpen(isOpen)
				open = isOpen
				PickerContainer.Visible = isOpen
				ExpandIcon.Text = isOpen and "−" or "+"
				if isOpen then
					PickerContainer.AutomaticSize = Enum.AutomaticSize.Y
					PickerContainer.Size = UDim2.new(1, 0, 0, 0)
				else
					activeDrag = nil
					PickerContainer.AutomaticSize = Enum.AutomaticSize.None
					PickerContainer.Size = UDim2.new(1, 0, 0, 0)
				end
			end

			TopBtn.MouseButton1Click:Connect(function()
				setPickerOpen(not open)
			end)

			local ClosePickerBtn = Instance.new("TextButton", PickerContainer)
			ClosePickerBtn.LayoutOrder = 99
			ClosePickerBtn.Size = UDim2.new(1, 0, 0, 28)
			ClosePickerBtn.Text = "Close"
			ClosePickerBtn.FontFace = Utility:GetFont(Enum.FontWeight.Medium)
			ClosePickerBtn.TextSize = 13
			Utility:Colorize(ClosePickerBtn, "BackgroundColor3", "DarkElement")
			Utility:Colorize(ClosePickerBtn, "TextColor3", "Text")
			Utility:Corner(ClosePickerBtn, UI.RadiusSm)
			ClosePickerBtn.AutoButtonColor = false
			ClosePickerBtn.MouseButton1Click:Connect(function()
				setPickerOpen(false)
			end)

			local function refreshGradients()
				local hueColor = Color3.fromHSV(h, 1, 1)
				ColorMap.BackgroundColor3 = hueColor
				SatGradient.Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
					ColorSequenceKeypoint.new(1, hueColor),
				})
				AlphaFill.BackgroundColor3 = getColor3()
			end

			local function refreshDots()
				MapDot.Position = UDim2.new(s, 0, 1 - v, 0)
				HueDot.Position = UDim2.new(h, 0, 0.5, 0)
				AlphaDot.Position = UDim2.new(a, 0, 0.5, 0)
			end

			local function UpdateColor()
				local col = getColor3()
				local rgbString = colorToRgbString(col)

				PreviewColor.BackgroundColor3 = col
				PreviewColor.BackgroundTransparency = 1 - a
				refreshGradients()
				refreshDots()

				RgbLabel.Text = string.format("RGB: %s   |   Alpha: %d%%", rgbString, math.floor(a * 100 + 0.5))

				if Library.Configurables[flag] then
					Library.Configurables[flag].Value = encodeConfigValue()
				end

				callback(rgbString, a, col)
			end

			local function setFromExternal(val, alphaOverride)
				applyParsedColor(val, alphaOverride)
				UpdateColor()
			end

			Library.Configurables[flag] = {
				Type = "ColorPicker",
				Value = encodeConfigValue(),
				Set = setFromExternal,
			}

			local function bindBarDrag(bar, dragId, onDrag)
				bar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						activeDrag = dragId
						onDrag(input)
					end
				end)
			end

			bindBarDrag(ColorMap, "map", function(input)
				local percentX = math.clamp((input.Position.X - ColorMap.AbsolutePosition.X) / ColorMap.AbsoluteSize.X, 0, 1)
				local percentY = math.clamp((input.Position.Y - ColorMap.AbsolutePosition.Y) / ColorMap.AbsoluteSize.Y, 0, 1)
				s = percentX
				v = 1 - percentY
				UpdateColor()
			end)

			bindBarDrag(HueBar, "hue", function(input)
				h = math.clamp((input.Position.X - HueBar.AbsolutePosition.X) / HueBar.AbsoluteSize.X, 0, 1)
				UpdateColor()
			end)

			bindBarDrag(AlphaBar, "alpha", function(input)
				a = math.clamp((input.Position.X - AlphaBar.AbsolutePosition.X) / AlphaBar.AbsoluteSize.X, 0, 1)
				UpdateColor()
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					activeDrag = nil
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if not activeDrag then return end
				if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
					if activeDrag == "map" then
						local percentX = math.clamp((input.Position.X - ColorMap.AbsolutePosition.X) / ColorMap.AbsoluteSize.X, 0, 1)
						local percentY = math.clamp((input.Position.Y - ColorMap.AbsolutePosition.Y) / ColorMap.AbsoluteSize.Y, 0, 1)
						s, v = percentX, 1 - percentY
					elseif activeDrag == "hue" then
						h = math.clamp((input.Position.X - HueBar.AbsolutePosition.X) / HueBar.AbsoluteSize.X, 0, 1)
					elseif activeDrag == "alpha" then
						a = math.clamp((input.Position.X - AlphaBar.AbsolutePosition.X) / AlphaBar.AbsoluteSize.X, 0, 1)
					end
					UpdateColor()
				end
			end)

			UpdateColor()

			return {
				get = function()
					return colorToRgbString(getColor3()), a, getColor3()
				end,
				set = function(_, val, alphaOverride)
					setFromExternal(val, alphaOverride)
				end,
			}
		end

		if customLayoutOrder == 9998 then
			buildPlayerProfilePanel(InnerBox, RegisterElement)
		end

		SectionAPI.Inner = InnerBox
		return SectionAPI
	end

	-- ==========================================
	-- ### PLAYER PROFILE & SETTINGS ###
	-- ==========================================
	Window:section(Player.DisplayName, 9998)

	local SettingsSection = Window:section("Settings", 9999)

	SettingsSection:create_dropdown({
		text = "Theme",
		list = {"Default", "Ocean", "Blood", "Forest", "Amethyst", "Midnight"},
		tooltip = "Velg fargetema for menyen",
		Callback = function(val) Library:SetTheme(val) end
	})

	SettingsSection:create_toogle({
		text = "Watermark",
		flag = "ShowWatermark",
		state = false,
		tooltip = "Viser FPS, Ping og tid i hjørnet",
		Callback = function(val) WatermarkUI.Visible = val end
	})

	SettingsSection:create_keybind({
		text = "Menu Keybind",
		flag = "MenuKeybind",
		default = Enum.KeyCode.RightShift,
		tooltip = "Bestemmer hvilken tast som skjuler scriptet",
		Callback = function(key)
			Library.ToggleKey = key
		end
	})

	local function UpdateConfigList()
		return listConfigNames()
	end

	SettingsSection:label(
		"Mappe: " .. Library.ConfigFolder,
		"Global lagring — samme configs i alle Roblox-spill (på denne PC-en)"
	)

	local ConfigNameInput = SettingsSection:create_input({
		text = "Skriv Config Navn...",
		tooltip = "Navnet på filen du vil lagre (f.eks. main eller mm2)"
	})

	local currentSelectedConfig = ""
	local ConfigDropdown = SettingsSection:create_dropdown({
		text = "Saved Configs",
		list = UpdateConfigList(),
		tooltip = "Velg en lagret config",
		Callback = function(val) currentSelectedConfig = val end
	})

	SettingsSection:create_button({
		text = "Save Config",
		tooltip = "Lagrer alle innstillinger globalt i " .. CONFIG_DIR_NAME,
		Callback = function()
			local ok, result = Library:SaveConfig(ConfigNameInput.Text)
			if not ok then
				Library:Notify("Feil", result, 3)
				return
			end
			Library:Notify("Lagret", "Config '" .. result .. "' → " .. Library.ConfigFolder, 5)
			ConfigDropdown:Refresh(UpdateConfigList())
		end
	})

	SettingsSection:create_button({
		text = "Load Config",
		tooltip = "Laster inn valgt config fra global mappe",
		Callback = function()
			if currentSelectedConfig == "" then Library:Notify("Feil", "Velg en config i menyen først!", 3) return end

			local ok, result = Library:LoadConfig(currentSelectedConfig)
			if ok then
				Library:Notify("Lastet inn", "Config '" .. result .. "' er lastet!", 4)
			else
				Library:Notify("Feil", result, 4)
			end
		end
	})

	SettingsSection:create_button({
		text = "Update Config",
		tooltip = "Overskriver valgt config med nåværende innstillinger",
		Callback = function()
			if currentSelectedConfig == "" then Library:Notify("Feil", "Velg en config å oppdatere!", 3) return end

			local ok, result = Library:SaveConfig(currentSelectedConfig)
			if ok then
				Library:Notify("Oppdatert", "Config '" .. result .. "' er overskrevet!", 4)
			else
				Library:Notify("Feil", result, 4)
			end
		end
	})

	return Window
end

return Library
