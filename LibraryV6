-- Global config (på tvers av Roblox-spill / PlaceId)
local CONFIG_DIR_NAME = "RobloxLibrary_Config"
local ConfigFolder = CONFIG_DIR_NAME
Library.ConfigFolder = ConfigFolder

local function sanitizeConfigName(name)
	name = tostring(name or ""):gsub("[%c/\\:*?\"<>|]", ""):gsub("^%s+", ""):gsub("%s+$", "")
	if name == "" then return nil end
	return name
end

local function configFilePath(configName)
	return ConfigFolder .. "/" .. configName .. ".json"
end

local function ensureConfigFolder()
	if not HasFileSystem then return false end

	local candidates = { "../" .. CONFIG_DIR_NAME, CONFIG_DIR_NAME }
	for _, path in ipairs(candidates) do
		local ok = pcall(function()
			if not isfolder(path) then makefolder(path) end
			local probe = path .. "/.write_test"
			writefile(probe, "ok")
			if isfile and isfile(probe) and delfile then delfile(probe) end
		end)
		if ok then
			ConfigFolder = path
			Library.ConfigFolder = path
			return true
		end
	end
	return false
end

local function migrateLegacyConfigs()
	if not HasFileSystem or not ensureConfigFolder() then return end
	if not isfolder("MyCheatHub") then return end

	for _, file in ipairs(listfiles("MyCheatHub")) do
		local name = file:match("([^/\\]+)%.json$")
		if name then
			local dest = configFilePath(name)
			if not (isfile and isfile(dest)) then
				pcall(function()
					writefile(dest, readfile(file))
				end)
			end
		end
	end
end

local function encodeConfigurables()
	local data = { _version = 1, _savedAt = os.time() }
	for flag, cfg in pairs(Library.Configurables) do
		data[flag] = cfg.Value
	end
	return HttpService:JSONEncode(data)
end

local function applyConfigJson(json)
	local data = HttpService:JSONDecode(json)
	for flag, val in pairs(data) do
		if type(flag) == "string" and flag:sub(1, 1) ~= "_" and Library.Configurables[flag] then
			Library.Configurables[flag].Set(val)
		end
	end
end

local function listConfigNames()
	local list = {}
	if not HasFileSystem then
		for name, _ in pairs(MockFilesystem) do
			table.insert(list, name)
		end
	else
		ensureConfigFolder()
		for _, file in ipairs(listfiles(ConfigFolder)) do
			local name = file:match("([^/\\]+)%.json$")
			if name and name ~= ".write_test" then
				table.insert(list, name)
			end
		end
	end
	table.sort(list)
	return list
end

function Library:SaveConfig(configName)
	local name = sanitizeConfigName(configName)
	if not name then return false, "Ugyldig config-navn" end

	local json = encodeConfigurables()
	if HasFileSystem then
		if not ensureConfigFolder() then return false, "Kunne ikke opprette config-mappe" end
		writefile(configFilePath(name), json)
	else
		MockFilesystem[name] = json
	end
	return true, name
end

function Library:LoadConfig(configName)
	local name = sanitizeConfigName(configName)
	if not name then return false, "Ugyldig config-navn" end

	local json
	if HasFileSystem then
		if not ensureConfigFolder() then return false, "Config-mappe finnes ikke" end
		local path = configFilePath(name)
		if isfile and not isfile(path) then return false, "Fant ikke config '" .. name .. "'" end
		local okRead, content = pcall(function()
			return readfile(path)
		end)
		if not okRead or not content then return false, "Fant ikke config '" .. name .. "'" end
		json = content
	else
		json = MockFilesystem[name]
	end

	if not json or json == "" then return false, "Tom eller manglende config" end

	local ok, err = pcall(function()
		applyConfigJson(json)
	end)
	if not ok then return false, tostring(err) end
	return true, name
end

if HasFileSystem then
	ensureConfigFolder()
	migrateLegacyConfigs()
end

