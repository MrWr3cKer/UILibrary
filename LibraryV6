function Utility:GetFont(weight)
	weight = weight or Enum.FontWeight.Medium
	local ok, font = pcall(function()
		return Font.new("rbxasset://fonts/families/GothamSSm.json", weight)
	end)
	if ok and font then return font end
	return Font.new("rbxasset://fonts/families/Arimo.json", weight)
end

function Utility:Corner(inst, radius)
	local corner = inst:FindFirstChildOfClass("UICorner")
	if not corner then corner = Instance.new("UICorner", inst) end
	corner.CornerRadius = UDim.new(0, radius or UI.Radius)
	return corner
end

function Utility:Stroke(inst, color, transparency)
	local stroke = inst:FindFirstChildOfClass("UIStroke")
	if not stroke then stroke = Instance.new("UIStroke", inst) end
	stroke.Color = color or Color3.fromRGB(255, 255, 255)
	stroke.Transparency = transparency ~= nil and transparency or 0.9
	stroke.Thickness = 1
	stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	return stroke
end

function Utility:Blend(c1, c2, t)
	return Color3.new(
		c1.R + (c2.R - c1.R) * t,
		c1.G + (c2.G - c1.G) * t,
		c1.B + (c2.B - c1.B) * t
	)
end

function Utility:Colorize(element, property, colorName)
	element[property] = Colors[colorName]
	table.insert(Library.ThemedElements, {Element = element, Property = property, ColorName = colorName})
end

function Utility:UpdateThemeColor(element, property, newColorName)
	for _, data in pairs(Library.ThemedElements) do
		if data.Element == element and data.Property == property then
			data.ColorName = newColorName
			return
		end
	end
	Utility:Colorize(element, property, newColorName)
end

function Library:SetTheme(themeName)
	if Themes[themeName] then
		Colors = Themes[themeName]
		for _, data in pairs(Library.ThemedElements) do
			if data.Element and data.Element.Parent then
				Utility:Tween(data.Element, {[data.Property] = Colors[data.ColorName]}, 0.3)
			end
		end
	end
end

Utility._activeTweens = setmetatable({}, { __mode = "k" })

function Utility:CancelTween(obj)
	local tw = self._activeTweens[obj]
	if tw then
		tw:Cancel()
		self._activeTweens[obj] = nil
	end
end

function Utility:Tween(obj, properties, duration, style, direction)
	if not obj or not obj.Parent then return nil end
	self:CancelTween(obj)
	local tweenInfo = TweenInfo.new(
		duration or UI.Dur,
		style or UI.Ease,
		direction or Enum.EasingDirection.Out
	)
	local tween = TweenService:Create(obj, tweenInfo, properties)
	self._activeTweens[obj] = tween
	tween.Completed:Connect(function(state)
		if state == Enum.PlaybackState.Completed and self._activeTweens[obj] == tween then
			self._activeTweens[obj] = nil
		end
	end)
	tween:Play()
	return tween
end

function Utility:TweenSequence(steps)
	task.spawn(function()
		for _, step in ipairs(steps) do
			local tw = self:Tween(step.obj, step.props, step.dur, step.style, step.dir)
			if tw and step.wait then
				tw.Completed:Wait()
			elseif step.dur then
				task.wait(step.dur)
			end
		end
	end)
end

function Utility:SpringIn(obj, props, duration)
	if not obj then return end
	local scale = obj:FindFirstChildOfClass("UIScale")
	if not scale then scale = Instance.new("UIScale", obj) end
	scale.Scale = 0.97
	self:Tween(scale, { Scale = 1 }, duration or 0.28, UI.Ease, Enum.EasingDirection.Out)
	if props then self:Tween(obj, props, duration or 0.28, UI.Ease, Enum.EasingDirection.Out) end
end

function Utility:Press(obj, shrink, grow)
	shrink = shrink or UDim2.new(0.988, 0, 0.975, 0)
	grow = grow or obj.Size
	self:TweenSequence({
		{ obj = obj, props = { Size = shrink }, dur = 0.05, style = Enum.EasingStyle.Quad, dir = Enum.EasingDirection.Out, wait = true },
		{ obj = obj, props = { Size = grow }, dur = 0.2, style = UI.Ease, dir = Enum.EasingDirection.Out },
	})
end

function Utility:HoverLift(obj, on, baseColor, liftColor)
	if on then
		self:Tween(obj, { BackgroundColor3 = liftColor }, 0.18, UI.Ease, Enum.EasingDirection.Out)
	else
		self:Tween(obj, { BackgroundColor3 = baseColor }, 0.2, UI.Ease, Enum.EasingDirection.Out)
	end
end

function Utility:StaggerChildren(container, childFilter, delayStep)
	local delay = 0
	for _, child in ipairs(container:GetChildren()) do
		if not childFilter or childFilter(child) then
			local scale = child:FindFirstChildOfClass("UIScale")
			if not scale then
				scale = Instance.new("UIScale", child)
			end
			scale.Scale = 0.9
			child.BackgroundTransparency = math.min(1, child.BackgroundTransparency + 0.2)
			task.delay(delay, function()
				if child.Parent then
					self:Tween(scale, { Scale = 1 }, 0.26, UI.Ease, Enum.EasingDirection.Out)
					self:Tween(child, { BackgroundTransparency = child:GetAttribute("_BaseTrans") or child.BackgroundTransparency }, 0.3)
				end
			end)
			delay = delay + (delayStep or 0.045)
		end
	end
end

function Utility:SlideFade(obj, show, offsetY)
	offsetY = offsetY or 14
	if show then
		obj.Visible = true
		local target = obj:GetAttribute("_SlideTargetPos")
		if target then
			obj.Position = UDim2.new(target.X.Scale, target.X.Offset, target.Y.Scale, target.Y.Offset + offsetY)
			self:Tween(obj, { Position = target }, 0.38, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
		end
	else
		local start = obj.Position
		obj:SetAttribute("_SlideTargetPos", start)
		self:Tween(obj, { Position = UDim2.new(start.X.Scale, start.X.Offset, start.Y.Scale, start.Y.Offset + offsetY) }, 0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.In).Completed:Connect(function()
			if obj.Parent then obj.Visible = false end
		end)
	end
end

function Utility:MakeDraggable(topBar, mainFrame)
	local dragging, dragInput, dragStart, startPos
	topBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = mainFrame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	topBar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
end

